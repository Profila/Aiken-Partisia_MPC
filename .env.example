# ─── Reviewer Quick Start ─────────────────────────────────────────────
# Most scripts fall back to deploy-m1.json / deploy-m3.json for addresses,
# so you only NEED the Blockfrost key below to run the relay.
# show_result.ts works with zero .env variables.
# ──────────────────────────────────────────────────────────────────────

# Blockfrost (Cardano preprod) — required for relay.ts
# Get a free key at https://blockfrost.io (select Preprod network)
BLOCKFROST_PROJECT_ID=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Optional overrides ──────────────────────────────────────────────
# These are read from deploy JSON files by default; set only to override.
# CARDANO_SCRIPT_ADDRESS=addr_test1wzut662xhd8e4jq97fpdsml2pyqerejwzfg24red2n7gceczhkwaz
# PBC_CONTRACT_ADDRESS=039ed9214602f2a93eb05411f852fa78a476607634
# PBC_TESTNET_URL=https://node1.testnet.partisiablockchain.com

# ─── Secret submission / trigger (admin only) ────────────────────────
# Not needed for verification. Only needed to submit new secrets or trigger.
# PBC_ACCOUNT_PRIVATE_KEY=
# CARDANO_WALLET_SKEY_PATH=./keys/payment.skey
# CARDANO_WALLET_ADDRESS=addr_test1...
